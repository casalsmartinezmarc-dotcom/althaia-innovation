# Supabase — Variables d'entorn necessàries
# Copia aquest fitxer a .env.local i omple els valors
# (mai comitis .env.local al repositori)

# 1. Ves a https://supabase.com i crea un projecte
# 2. Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# 3. Settings → API → Project API Keys → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
